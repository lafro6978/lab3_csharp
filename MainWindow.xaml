<Window x:Class="wpflab3.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:oxy="http://oxyplot.org/wpf"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Margin="10">
            <Button Name="BtnLoad" Content="Загрузить данные" Click="BtnLoad_Click" Margin="0,0,0,10"/>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <Button Name="BtnUndo" Content="Undo" Click="BtnUndo_Click" Width="100" Margin="0,0,10,0"/>
                <Button Name="BtnRedo" Content="Redo" Click="BtnRedo_Click" Width="100"/>
            </StackPanel>

            <TextBlock Text="Входные данные:" FontWeight="Bold"/>
            <TextBlock Name="TxtInputData" TextWrapping="Wrap" Margin="0,5,0,0"/>
        </StackPanel>

        <oxy:PlotView Grid.Column="1" x:Name="MainPlotView" Margin="10"/>
    </Grid>
</Window>